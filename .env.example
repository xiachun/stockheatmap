# Local environment example.
# The server loads .env on startup; shell environment variables still take precedence.

# iFinD credential
# THS_REFRESH_TOKEN=your_ifind_refresh_token

# Optional server settings
PORT=3000
IFIND_DEBUG=0
IFIND_DEBUG_LOG_FILE=./data/ifind-debug.log

# Optional sample universe settings
IFIND_SAMPLE_INDEX_CODE=000300.SH
# Optional; if omitted, the server will resolve the index short name from iFinD
# IFIND_SAMPLE_INDEX_NAME=沪深300

# Optional cache tuning
CACHE_SWEEP_INTERVAL_MS=600000
CACHE_MAX_TRADE_RANGE=5000
CACHE_MAX_TRADE_OFFSET=5000
CACHE_MAX_SAMPLE_MEMBERS=512
CACHE_MAX_FLOAT_MV=1500
CACHE_MAX_VALUATIONS=64
CACHE_MAX_RETURNS=6000
CACHE_MAX_HEATMAP=1500

# Optional response compression threshold in bytes
JSON_COMPRESS_MIN_BYTES=2048

# Optional lower bound for latest force refreshes
LATEST_FORCE_REFRESH_MIN_INTERVAL_MS=1000
